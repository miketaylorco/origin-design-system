{
  "avatar": {
    "size": {
      "sm": {
        "$type": "dimension",
        "$value": "32px"
      },
      "md": {
        "$type": "dimension",
        "$value": "40px"
      },
      "lg": {
        "$type": "dimension",
        "$value": "56px"
      }
    },
    "icon-size": {
      "sm": {
        "$type": "dimension",
        "$value": "16px"
      },
      "md": {
        "$type": "dimension",
        "$value": "20px"
      },
      "lg": {
        "$type": "dimension",
        "$value": "24px"
      }
    },
    "font-size": {
      "sm": {
        "$type": "number",
        "$value": "{font-size.body.xs}"
      },
      "md": {
        "$type": "number",
        "$value": "{font-size.body.sm}"
      },
      "lg": {
        "$type": "number",
        "$value": "{font-size.body.lg}"
      }
    },
    "radius": {
      "$type": "number",
      "$value": "{radius.full}"
    },
    "focus": {
      "ring-width": {
        "$type": "number",
        "$value": "{focus.ring-width}"
      },
      "ring-offset": {
        "$type": "number",
        "$value": "{focus.ring-offset}"
      },
      "ring-radius": {
        "$type": "number",
        "$value": "{focus.ring-radius.full}"
      }
    },
    "neutral": {
      "background": {
        "$type": "color",
        "$value": "{background.subdued}"
      },
      "foreground": {
        "$type": "color",
        "$value": "{text.subdued}"
      },
      "background-hover": {
        "$type": "color",
        "$value": "{background.raised}"
      }
    },
